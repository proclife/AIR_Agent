#!/usr/bin/env python3
"""
akshare 数据获取脚本
用途：自动获取股票K线数据，更新02_市场数据/历史数据/
"""

import os
import akshare as ak
import pandas as pd
from datetime import datetime, timedelta

# 配置
PROJECT_PATH = "/Users/humiles/OpenClaw项目/莫大韭菜"
HIST_DATA_DIR = f"{PROJECT_PATH}/02_市场数据/历史数据"

# 用户持仓股（需要重点更新）
HOLDINGS = {
    "000762": "西藏矿业",   # 锂矿
    "002594": "比亚迪",    # 新能源车
    "002169": "智光电气",  # 储能
    "600343": "航天动力",  # 商业航天
    "688114": "华大智造", # AI医疗
    "601020": "华钰矿业",  # 锑矿
    "002538": "司尔特",   # 磷矿
    "688559": "海目星",   # 激光设备
    "300034": "钢研高纳", # 高温合金
    "688533": "上大股份",  # 航发
}

# 指数（需要更新）
INDICES = {
    "000001": "上证指数",
    "399001": "深证成指",
    "399006": "创业板指",
    "000300": "沪深300",
    "000016": "上证50",
    "000905": "中证500",
    "399102": "创业板指",
}

# ETF
ETFS = {
    "510500": "512500",
    "159920": "华夏上证50ETF",
    "512880": "证券ETF",
}


def get_stock_kline(symbol: str, adjust: str = "qfq") -> pd.DataFrame:
    """获取个股K线数据"""
    try:
        df = ak.stock_zh_a_hist(symbol=symbol, period="daily", start_date="20200101",
                              end_date=datetime.now().strftime("%Y%m%d"), adjust=adjust)
        return df
    except Exception as e:
        print(f"获取 {symbol} 失败: {e}")
        return None


def get_index_kline(symbol: str) -> pd.DataFrame:
    """获取指数K线数据"""
    try:
        df = ak.stock_zh_index_daily(symbol=symbol)
        return df
    except Exception as e:
        print(f"获取指数 {symbol} 失败: {e}")
        return df


def save_to_csv(df: pd.DataFrame, filepath: str):
    """保存到CSV，追加模式"""
    if df is None or df.empty:
        return False
    
    # 列名映射（akshare格式）
    column_map = {
        '日期': 'date',
        '开盘': 'open',
        '收盘': 'close',
        '最高': 'high',
        '最低': 'low',
        '成交量': 'volume',
        '成交额': 'amount',
        '振幅': 'amplitude',
        '涨跌幅': 'pct_change',
        '涨跌额': 'change',
        '换手率': 'turnover',
    }
    
    # 标准化列名
    df = df.rename(columns=column_map)
    
    # 如果文件存在，追加新数据
    if os.path.exists(filepath):
        existing = pd.read_csv(filepath)
        # 获取最新日期
        existing_date = pd.to_datetime(existing['date']).max()
        new_date = pd.to_datetime(df['date']).max()
        if new_date > existing_date:
            # 追加新数据
            df = df[pd.to_datetime(df['date']) > existing_date]
            df = pd.concat([existing, df], ignore_index=True)
            print(f"  {filepath}: 更新 {existing_date.date()} → {new_date.date()}")
        else:
            print(f"  {filepath}: 无新数据 ({new_date.date()})")
            return False
    else:
        print(f"  {filepath}: 新建")
    
    df.to_csv(filepath, index=False, encoding='utf-8')
    return True


def main(update_holdings=True, update_indices=True, update_etfs=False):
    """主函数"""
    print(f"\n=== akshare 数据获取 ===")
    print(f"时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    
    count = 0
    
    # 1. 更新持仓股
    if update_holdings:
        print(f"\n--- 持仓股 ({len(HOLDINGS)}) ---")
        for code, name in HOLDINGS.items():
            print(f"{code} {name}")
            df = get_stock_kline(code)
            if df is not None:
                save_to_csv(df, f"{HIST_DATA_DIR}/{code}.csv")
                count += 1
    
    # 2. 更新指数
    if update_indices:
        print(f"\n--- 指数 ({len(INDICES)}) ---")
        for code, name in INDICES.items():
            print(f"{code} {name}")
            df = get_index_kline(code)
            if df is not None:
                save_to_csv(df, f"{HIST_DATA_DIR}/{code}.csv")
                count += 1
    
    # 3. ETF（可选）
    if update_etfs:
        print(f"\n--- ETF ({len(ETFS)}) ---")
        for code, name in ETFS.items():
            print(f"{code} {name}")
            df = get_stock_kline(code)
            if df is not None:
                save_to_csv(df, f"{HIST_DATA_DIR}/ETF_{code}.csv")
                count += 1
    
    print(f"\n=== 完成: 更新 {count} 个标的 ===")


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("--all", action="store_true", help="更新所有（含ETF）")
    parser.add_argument("--holdings", action="store_true", help="仅持仓股")
    parser.add_argument("--indices", action="store_true", help="仅指数")
    args = parser.parse_args()
    
    if args.all:
        main(True, True, True)
    elif args.holdings:
        main(True, False, False)
    elif args.indices:
        main(False, True, False)
    else:
        main(True, True, False)  # 默认：持仓+指数
